# Environment configuration for github-commit-surge
#
# Rules:
# - Copy to `.env` and fill in real values (never commit `.env`)
# - Every variable used by the pipeline or scripts must be documented here
# - `./scripts/check-env.sh` validates that required keys exist in `.env`
#
# Setup:
#   cp .env.example .env
#   ./scripts/check-env.sh

# ── Google Cloud ────────────────────────────────────────────────────────────
# Your GCP project ID (must have BigQuery API enabled and billing set up)
# This is a SEPARATE project from any personal/production GCP accounts.
GCP_PROJECT_ID=your-gcp-project-id

# Optional: BigQuery dataset name to store intermediate results
# Will be created automatically if it does not exist
BQ_DATASET=github_stats_work

# ── GitHub ──────────────────────────────────────────────────────────────────
# Personal access token — no scopes needed (public data only)
# Create at: https://github.com/settings/tokens → "Generate new token (classic)"
# Select no scopes. Name it something like "github-commit-surge-read"
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Pipeline parameters ─────────────────────────────────────────────────────
# Number of candidate users to sample in step 01 (default: 60000)
# Filtered down to ~5k-15k confirmed pre-2019 human accounts after step 03
SAMPLE_SIZE=60000

# Threads for GitHub API enrichment in step 03 (stay under rate limit)
GH_API_THREADS=4

# ── Local dev ───────────────────────────────────────────────────────────────
APP_NAME=github-commit-surge
APP_ENV=local
APP_PORT=
DEV_URL=
