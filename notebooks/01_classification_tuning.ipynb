{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Cohort Classification Tuning\n",
    "\n",
    "Run *after* steps 01-03 have produced `data/raw/yearly_commits.parquet`.\n",
    "Use this notebook to explore threshold sensitivity before committing to\n",
    "values in `config.py`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import pipeline.config as cfg\n",
    "from pipeline.pipeline04_classify_cohorts import build_wide, classify_row, YEARS, PRE_ERA, POST_ERA\n",
    "\n",
    "df_commits  = pd.read_parquet(cfg.DATA_RAW / 'yearly_commits.parquet')\n",
    "df_profiles = pd.read_parquet(cfg.DATA_RAW / 'gh_profiles.parquet')\n",
    "wide        = build_wide(df_commits)\n",
    "print(f\"{len(wide):,} users loaded\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Distribution of pre-era means — helps calibrate DORMANT_MAX_PRE_MEAN\n",
    "pre_means = wide[PRE_ERA].mean(axis=1)\n",
    "print(pre_means.describe())\n",
    "pre_means.clip(upper=200).hist(bins=50)\n",
    "plt.title('Distribution of pre-2019 mean annual commits')\n",
    "plt.xlabel('Mean commits/year (2011–2018)')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Sweep over DORMANT_MAX_PRE_MEAN threshold — how many users get classified as dormant?\n",
    "post_means = wide[POST_ERA].mean(axis=1)\n",
    "for threshold in [5, 10, 15, 20, 30]:\n",
    "    n = ((pre_means <= threshold) & (post_means >= 30)).sum()\n",
    "    pct = 100 * n / len(wide)\n",
    "    print(f\"  pre_mean <= {threshold:>2}  →  {n:>5,} dormant candidates  ({pct:.1f}%)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Surge ratio distribution for likely-dormant users\n",
    "likely_dormant = wide[(pre_means <= 10) & (post_means >= 30)]\n",
    "surge_ratios = post_means[likely_dormant.index] / (pre_means[likely_dormant.index] + 1)\n",
    "print(surge_ratios.describe())\n",
    "surge_ratios.clip(upper=100).hist(bins=40)\n",
    "plt.title('Surge ratios for dormant candidates')\n",
    "plt.xlabel('surge_ratio = post_mean / (pre_mean + 1)')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Inflection year distribution — where did the surge happen?\n",
    "import pipeline.pipeline04_classify_cohorts as p4\n",
    "classifications = [p4.classify_row(wide.loc[l]) for l in wide.index]\n",
    "df_class = pd.DataFrame(classifications, index=wide.index)\n",
    "\n",
    "surgers = df_class[df_class['cohort'].isin(['dormant_reactivated', 'new_surger'])]\n",
    "surgers['inflection_year'].dropna().astype(int).value_counts().sort_index().plot.bar(color='#e05c2a')\n",
    "plt.title('Inflection year distribution')\n",
    "plt.xlabel('Year')\n",
    "plt.ylabel('Number of users')\n",
    "plt.axvline(x=surgers['inflection_year'].dropna().astype(int).tolist().index(2022),\n",
    "            color='white', linestyle='--', label='Copilot GA')\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  }
 ],
